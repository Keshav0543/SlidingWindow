{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run C++",
      "type": "shell",
      "command": "g++ ${file} -o ${fileDirname}\\${fileBasenameNoExtension}.exe; if ($?) { .\\${fileBasenameNoExtension}.exe }",
      "options": {
        "cwd": "${fileDirname}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}